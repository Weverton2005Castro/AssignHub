NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql://subscriptionhub:subscriptionhub@localhost:5432/subscriptionhub?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters
# 64 hex chars = 32 bytes for AES-256-GCM
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SubscriptionHub <noreply@subscriptionhub.local>"

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gmail OAuth (obrigatório para Gmail + recibos de lojas)
# Redirect: {API_URL}/api/v1/integrations/GMAIL/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Open Finance Brasil via Pluggy (transações reais)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_API_URL=https://api.pluggy.ai
PLUGGY_WEBHOOK_URL=

# Microsoft Graph (opcional; senão Microsoft usa recibos via Gmail)
# Redirect: {API_URL}/api/v1/integrations/MICROSOFT/oauth/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=subscriptionhub

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

FCM_SERVER_KEY=

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
